{
    "version": "0.2.0",
    "configurations": [{
        "name": "DeGSA debugger",
        "type": "cppdbg",
        "request": "launch",
        "program": "${workspaceRoot}/a.out",
        "args": [
            "prepr.fa",
            "debugPath/source.fa"
        ],
        "stopAtEntry": false,
        "cwd": "${workspaceFolder}",
        "environment": [],
        "externalConsole": false,
        "MIMode": "gdb", // requires gdb to be installed
        "preLaunchTask": "DeGSA_compile"

    },
    {
        "name": "ADAPT debugger",
        "type": "cppdbg",
        "request": "launch",
        "program": "${workspaceRoot}/adapt.out",
        "args": [
            "prepr.fa"
        ],
        "stopAtEntry": false,
        "cwd": "${workspaceFolder}",
        "environment": [],
        "externalConsole": false,
        "MIMode": "gdb", // requires gdb to be installed
        "preLaunchTask": "ADAPT_compile"

    },
    {
        "name": "PhASAR-advisor debugger",
        "type":"lldb-dap",
        "request": "launch",
        "program": "${workspaceFolder}/llvm-manager/build/bin/PhASAR-advisor",
        "args": [
            "/home/pyro/WorkDir/Study/practice/IR/tmpFiles/myVariants/base6/output.ll",
            "--html-report"
        ],
        "stopOnEntry": false,
        "cwd": "${workspaceFolder}"
    }
    ]
}
